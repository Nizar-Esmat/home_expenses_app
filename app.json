{
  "expo": {
    "name": "BudgetBuddy",
    "slug": "budget-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#091413",
      "image": "./assets/splash.png",
      "resizeMode": "contain"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091413",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.budgetbuddy.app"
    },
    "ios": {
      "bundleIdentifier": "com.budgetbuddy.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": false
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "scheme": "budgetbuddy",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "183f3398-be6f-4e9c-9d4f-49e6d4a9a6a4"
      }
    }
  }
}
